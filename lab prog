12. Write a program to create a voting application using React JS

Code : App.js

import React, { useState } from "react";

function App() {
  const [hansini, setHansini] = useState(0);
  const [yasasvi, setYasasvi] = useState(0);
  const [adifa, setAdifa] = useState(0);

  const maxVotes = Math.max(hansini, yasasvi, adifa);
  let winner = maxVotes === 0 ? "No votes yet" :
               maxVotes === hansini ? "Hansini" :
               maxVotes === yasasvi ? "Yasasvi" : "Adifa";

  return (
    <div style={{ textAlign: "center", marginTop: "50px" }}>
      <h1>Simple Counter App</h1>
      <h2>Winner: {winner} ({maxVotes})</h2>

      <h3>Hansini Votes: {hansini}</h3>
      <button onClick={() => setHansini(hansini + 1)}>Vote Hansini</button>

      <h3>Yasasvi Votes: {yasasvi}</h3>
      <button onClick={() => setYasasvi(yasasvi + 1)}>Vote Yasasvi</button>

      <h3>Adifa Votes: {adifa}</h3>
      <button onClick={() => setAdifa(adifa + 1)}>Vote Adifa</button>
    </div>
  );
}

export default App;

13. Develop a leave management system for an organization where users can apply different types of
leaves such as casual leave and medical leave. They also can view the available number of days
using react application.

Code : App.js

import React, { useState } from "react";

function App() {
  const [casualLeave, setCasualLeave] = useState(10);
  const [medicalLeave, setMedicalLeave] = useState(8);
  const [clDays, setClDays] = useState("");
  const [mlDays, setMlDays] = useState("");

  const applyCL = () => clDays>0 && clDays<=casualLeave ? (setCasualLeave(casualLeave-clDays), setClDays("")) : alert("Invalid CL");
  const applyML = () => mlDays>0 && mlDays<=medicalLeave ? (setMedicalLeave(medicalLeave-mlDays), setMlDays("")) : alert("Invalid ML");
  const resetLeaves = () => (setCasualLeave(10), setMedicalLeave(8));

  return (
    <div style={{textAlign:"center", marginTop:50}}>
      <h1>Leave Management</h1>
      <h2>Casual Leave: {casualLeave}</h2>
      <input type="number" value={clDays} onChange={e=>setClDays(Number(e.target.value))}/>
      <button onClick={applyCL}>Apply CL</button>

      <h2>Medical Leave: {medicalLeave}</h2>
      <input type="number" value={mlDays} onChange={e=>setMlDays(Number(e.target.value))}/>
      <button onClick={applyML}>Apply ML</button>

      <br/><br/>
      <button onClick={resetLeaves}>Reset</button>
    </div>
  );
}

export default App;

14.Write a program to create a simple calculator Application using React JS.

Code : App.js

import React, { useState } from "react";

function App() {
  const [input, setInput] = useState("");

  const handleClick = (val) => setInput(input + val);
  const calculate = () => setInput(eval(input).toString());
  const clear = () => setInput("");

  return (
    <div style={{ textAlign: "center", marginTop: 30 }}>
      <h1>Calculator</h1>
      <input type="text" value={input} readOnly />
      <br /><br />
      <button onClick={() => handleClick("7")}>7</button>
      <button onClick={() => handleClick("8")}>8</button>
      <button onClick={() => handleClick("9")}>9</button>
      <button onClick={() => handleClick("/")}>/</button>
      <br />
      <button onClick={() => handleClick("4")}>4</button>
      <button onClick={() => handleClick("5")}>5</button>
      <button onClick={() => handleClick("6")}>6</button>
      <button onClick={() => handleClick("*")}>*</button>
      <br />
      <button onClick={() => handleClick("1")}>1</button>
      <button onClick={() => handleClick("2")}>2</button>
      <button onClick={() => handleClick("3")}>3</button>
      <button onClick={() => handleClick("-")}>-</button>
      <br />
      <button onClick={() => handleClick("0")}>0</button>
      <button onClick={() => handleClick(".")}>.</button>
      <button onClick={calculate}>=</button>
      <button onClick={() => handleClick("+")}>+</button>
      <br /><br />
      <button onClick={clear}>C</button>
    </div>
  );
}

export default App;
