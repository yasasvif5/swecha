7. Water Jug Problem
from collections import deque

def water_jug(x, y, target):
    visited = set()
    q = deque([(0, 0)])

    while q:
        a, b = q.popleft()

        if (a, b) in visited:
            continue
        visited.add((a, b))

        print(a, b)

        if a == target or b == target:
            return

        q.append((x, b))      # fill jug1
        q.append((a, y))      # fill jug2
        q.append((0, b))      # empty jug1
        q.append((a, 0))      # empty jug2

        # pour jug1 -> jug2
        transfer = min(a, y - b)
        q.append((a - transfer, b + transfer))

        # pour jug2 -> jug1
        transfer = min(b, x - a)
        q.append((a + transfer, b - transfer))

water_jug(4, 3, 2)

