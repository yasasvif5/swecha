8. travelling salesman
from itertools import permutations

graph = [
    [0, 10, 15, 20],
    [10, 0, 35, 25],
    [15, 35, 0, 30],
    [20, 25, 30, 0]
]

n = len(graph)
cities = list(range(n))

min_path = float('inf')

for perm in permutations(cities[1:]):
    cost = 0
    k = 0
    for j in perm:
        cost += graph[k][j]
        k = j
    cost += graph[k][0]

    min_path = min(min_path, cost)

print("Minimum cost:", min_path)



