12. N-queens

N = 8

def safe(board, row, col):
    for i in range(row):
        if board[i] == col or abs(board[i] - col) == abs(i - row):
            return False
    return True

def solve(board, row):
    if row == N:
        print(board)
        return True

    for col in range(N):
        if safe(board, row, col):
            board[row] = col
            if solve(board, row + 1):
                return True
    return False

board = [-1] * N
solve(board, 0)
